# Sample environment file. Copy to .env and fill in your values:
#   cp .env.example .env
# .env is git-ignored; this file (.env.example) is safe to commit.

# Anthropic API key (https://console.anthropic.com) — used by the Claude baseline
# (src/claude/run_claude.py), which runs the same tools/prompts through Claude Sonnet.
ANTHROPIC_API_KEY=

# --- Web tool backends (src/backends.py) ----------------------------------------
# The live web_search/scrape_url are backed by a pluggable provider, chosen with
# --search-backend / --scrape-backend. Set only the key(s) for the backend(s) you
# use; pass --offline to skip all of them and use the local stub.
#
#   backend      search  scrape   key
#   firecrawl      x       x      FIRECRAWL_API_KEY   (default for both)
#   tavily         x       x      TAVILY_API_KEY
#   brave          x       -      BRAVE_API_KEY
#   jina           x       x      JINA_API_KEY
#   browserless    -       x      BROWSERLESS_API_KEY

# Firecrawl (https://firecrawl.dev) — search + scrape; the default backend.
FIRECRAWL_API_KEY=

# Tavily (https://tavily.com) — search + extract.
TAVILY_API_KEY=

# Brave Search (https://brave.com/search/api) — search only.
BRAVE_API_KEY=

# Jina AI (https://jina.ai) — search (s.jina.ai) + scrape (r.jina.ai).
JINA_API_KEY=

# Browserless (https://browserless.io) — scrape only (rendered HTML → markdown).
# Optional: override the region base URL (default https://production-sfo.browserless.io).
BROWSERLESS_API_KEY=
# BROWSERLESS_BASE_URL=https://production-sfo.browserless.io
