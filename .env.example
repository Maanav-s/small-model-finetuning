# Sample environment file. Copy to .env and fill in your values:
#   cp .env.example .env
# .env is git-ignored; this file (.env.example) is safe to commit.

# Anthropic API key (https://console.anthropic.com) — used by the Claude baseline
# (src/claude/run_claude.py), which runs the same tools/prompts through Claude Sonnet.
ANTHROPIC_API_KEY=

# --- Web tools (src/backends.py) -------------------------------------------------
# The live web_search/scrape_url are backed by Brave (search) and Jina (scrape).
# Set both keys for the live path; pass --offline to skip them and use the local
# stub instead.

# Brave Search (https://brave.com/search/api) — backs web_search.
BRAVE_API_KEY=

# Jina AI (https://jina.ai) — backs scrape_url (r.jina.ai).
JINA_API_KEY=
