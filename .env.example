# Sample environment file. Copy to .env and fill in your values:
#   cp .env.example .env
# .env is git-ignored; this file (.env.example) is safe to commit.

# Anthropic API key (https://console.anthropic.com) — used by the Claude baseline
# (src/claude/run_claude.py), which runs the same tools/prompts through Claude Sonnet.
ANTHROPIC_API_KEY=

# --- Web tools (src/backends.py) -------------------------------------------------
# The live web_search/scrape_url are backed by Brave (search) and Jina (scrape).
# Set both keys for the live path; pass --offline to skip them and use the local
# stub instead.

# Brave Search (https://brave.com/search/api) — backs web_search.
BRAVE_API_KEY=

# Jina AI (https://jina.ai) — backs scrape_url (r.jina.ai).
JINA_API_KEY=

# --- Phase 2: corpus store + optional sourcing enrichment (phase2_plan.md) -------
# S3 is the source of truth for the cache + corpus; `data/` is synced, not
# committed (scripts/cache_sync.py). On the training node prefer an EC2 instance
# profile / IAM role (no static keys, free same-region egress); the AWS_* vars
# below are the fallback for off-AWS boxes.
S3_BUCKET=
S3_PREFIX=menu-corpus
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=

# Google Places (New) API key — OPTIONAL. Only used by --enrich-places in
# scripts/harvest_restaurants.py for price-tier / chain signal. Requires a GCP
# project with billing enabled + a restricted key. OSM/Overpass needs no key.
GOOGLE_PLACES_API_KEY=
